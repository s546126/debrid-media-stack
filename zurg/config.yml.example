# Copy to zurg/config.yml and set your Real-Debrid token.
#   cp zurg/config.yml.example zurg/config.yml
zurg: v1
token: YOUR_REAL_DEBRID_API_TOKEN        # https://real-debrid.com/apitoken
# host: "[::]"
# port: 9999
# username:
# password:
# proxy:
# concurrent_workers: 20
check_for_changes_every_secs: 10
# repair_every_mins: 60
enable_repair: true
auto_delete_rar_torrents: true
# Optional: trigger a Plex partial scan when zurg detects library changes.
# 1. Edit zurg/scripts/plex_update.sh and set your Plex URL + token.
# 2. Install xmllint in the zurg container: docker compose exec zurg apk add libxml2-utils
#    NOTE: `exec ... apk add` only modifies the RUNNING container — the package is
#    lost on every image pull/recreate, silently breaking this hook. For a
#    persistent setup, build a tiny derived image (FROM ghcr.io/debridmediamanager/zurg-testing
#    + RUN apk add libxml2-utils) or rewrite plex_update.sh to not need xmllint.
# 3. Uncomment the line below. (Jellyfin picks up changes on its own scan schedule.)
# on_library_update: sh plex_update.sh "$@"

directories:
  anime:
    group_order: 10
    group: media
    filters:
      - regex: /\b[a-fA-F0-9]{8}\b/
      - any_file_inside_regex: /\b[a-fA-F0-9]{8}\b/

  shows:
    group_order: 20
    group: media
    filters:
      - has_episodes: true

  movies:
    group_order: 30
    group: media
    only_show_the_biggest_file: true
    filters:
      - regex: /.*/
