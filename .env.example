# Copy to .env (which is gitignored) and fill in.
#
#   cp .env.example .env && chmod 600 .env

# Tailscale auth key. Generate at:
#   Tailscale admin -> Settings -> Keys -> Generate auth key
# Requirements:
#   - Reusable       (one key onboards all 7 sidecar nodes — 8 with the alist profile)
#   - NON-ephemeral  (state is persisted; ephemeral nodes get removed on disconnect)
#   - Tagged — RECOMMENDED, e.g. tag:media (define the tag in your tailnet policy
#     first). Tagged nodes have node-key expiry DISABLED by default; untagged
#     nodes expire after ~180 days and every sidecar drops off the tailnet at
#     once. If you skip the tag, disable key expiry per node in the admin console.
# The key is only needed for the FIRST login (TS_AUTH_ONCE): after it expires
# (max 90 days) existing sidecars keep working from their persisted state —
# generate a new key only when onboarding new sidecars.
# Note: this value is visible via `docker inspect` on every sidecar container.
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx

# Host user/group that owns the bind-mounted config dirs and the media library.
# Run `id` to find yours.
PUID=1000
PGID=1000
TZ=UTC

# ── optional: media-butler chatbot agent (compose profile "agent") ───────────
# Any OpenAI-compatible endpoint (OpenAI, LiteLLM, one-api, cli-proxy-api, ...).
# Base URL only — the agent appends /v1/... itself (a trailing /v1 is tolerated).
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=sk-xxxxxxxxxxxx
# Jellyseerr -> Settings -> General -> API Key
JELLYSEERR_KEY=xxxxxxxxxxxx
# Once you enable the media-butler agent, uncomment this so every plain
# `docker compose up -d` keeps managing (and recreating) the agent service:
#COMPOSE_PROFILES=agent
# ALLOW_ORIGIN: leave unset. The portal reaches the agent same-origin via the
# nginx /agent/ proxy; set an explicit origin only if a genuinely different
# origin must call the agent ("*" is never honored).
